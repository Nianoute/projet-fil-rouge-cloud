# Environment variables for TaskFlow application
REDIS_URL=redis://redis:6379
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
DATABASE_URL=postgresql://<user>:<password>@postgres:5432/taskflow # fill user:password
JWT_SECRET= # required — change in production
JWT_EXPIRY=3600

# Database configuration
POSTGRES_USER= # required
POSTGRES_PASSWORD= # required
POSTGRES_DB=taskflow

# User Service configuration
USER_SERVICE_PORT=3001
USER_SERVICE_URL=http://user-service:3001
USER_SERVICE_OTEL_SERVICE_NAME=user-service

USER_SERVICE_DB_HOST=postgres
USER_SERVICE_DB_PORT=5432
USER_SERVICE_DB_NAME=taskflow_users
USER_SERVICE_DB_PASSWORD= # required — même valeur que POSTGRES_PASSWORD
USER_SERVICE_LOG_LEVEL=info
USER_SERVICE_NODE_ENV=production

# Task Service configuration
TASK_SERVICE_PORT=3002
TASK_SERVICE_URL=http://task-service:3002
TASK_SERVICE_OTEL_SERVICE_NAME=task-service

# Notification Service configuration
NOTIFICATION_SERVICE_PORT=3003
NOTIFICATION_SERVICE_URL=http://notification-service:3003
NOTIFICATION_SERVICE_OTEL_SERVICE_NAME=notification-service

# API Gateway configuration
API_GATEWAY_PORT=3000
API_GATEWAY_URL=http://api-gateway:3000
API_GATEWAY_OTEL_SERVICE_NAME=api-gateway

